<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Game Lab - Ituze</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    :root {
      --accent: #00d2ff; 
      --matrix-color: #00d2ff;
      --glass-bg: rgba(0, 15, 30, 0.7);
      --glass-border: rgba(0, 210, 255, 0.3);
      --text-main: #e0f7ff;
      --bg: #02060d;
    }

    body, html {
      margin: 0;
      padding: 0;
      height: 100%;
      background: var(--bg);
      color: var(--text-main);
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      overflow: hidden;
      user-select: none; /* Prevents text highlighting */
    }

    /* Matrix Background */
    #matrix {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      opacity: 0.5;
    }

    /* Main Hub UI */
    #menu {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 10vh;
      height: 100vh;
      background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.85) 100%);
      overflow-y: auto;
    }

    #greeting {
      font-size: 3rem;
      font-weight: 300;
      margin-bottom: 50px;
      letter-spacing: 2px;
      color: var(--text-main);
      text-shadow: 0 0 30px rgba(0, 210, 255, 0.5);
    }

    .button-container {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
      justify-content: center;
      max-width: 1200px;
      padding-bottom: 80px;
    }

    /* Game Card Styling */
    .game-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      width: 300px; /* Requested Width */
      padding: 30px 0;
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      cursor: pointer;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      font-size: 1.4rem; /* Requested Font Size */
      font-weight: 600; /* Requested Font Weight */
      color: var(--text-main);
      text-align: center;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      text-transform: uppercase;
      letter-spacing: 1px;
      position: relative;
    }

    .game-card:hover {
      background: rgba(0, 210, 255, 0.15);
      border-color: var(--accent);
      transform: translateY(-10px);
      box-shadow: 0 0 40px rgba(0, 210, 255, 0.3);
      color: #fff;
    }

    .add-btn {
      border-style: dashed;
      opacity: 0.6;
    }

    /* Custom Right-Click Menu */
    #custom-menu {
      display: none;
      position: absolute;
      background: #00d2ff;
      color: #000;
      padding: 10px 25px;
      font-weight: 800;
      border-radius: 4px;
      z-index: 1000;
      cursor: pointer;
      font-size: 0.9rem;
      text-transform: uppercase;
    }

    /* Game Stage */
    #stage {
      display: none;
      flex-direction: column;
      height: 100vh;
      width: 100vw;
      position: relative;
      z-index: 10;
      background: #000;
    }

    #controls {
      background: rgba(5, 10, 20, 0.95);
      padding: 12px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--glass-border);
    }

    #stage:fullscreen #controls { display: none; }

    .btn {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 10px 25px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 700;
      transition: 0.3s;
      text-transform: uppercase;
    }

    .btn:hover { background: var(--accent); color: #000; }

    iframe { width: 100%; height: 100%; border: none; }
  </style>
</head>
<body oncontextmenu="return false;"> <canvas id="matrix"></canvas>

  <div id="custom-menu">Open Game</div>

  <div id="menu">
    <h1 id="greeting">Welcome, Ituze</h1>
    
    <div class="button-container" id="gameList">
      <div class="game-card" onclick="loadGame('https://ozgames.io/geometry-dash.embed')">Geometry Dash</div>
      <div class="game-card" onclick="loadGame('https://geometrylitepc.io/slope-2.embed')">Slope 2</div>
      <div class="game-card" onclick="loadGame('https://smash-karts.game-files.crazygames.com/smash-karts/177/index.html?isNewUser=false&skipPrerollFirstSession=true')">Smash Karts</div>
      <div class="game-card" onclick="loadGame('https://escaperoad.io/escape-road')">Escape Road</div>

      <div class="game-card add-btn" onclick="addCustomGame()">+ Add Game</div>
    </div>
  </div>

  <div id="stage">
    <div id="controls">
      <button class="btn" onclick="goBack()">← Exit to Hub</button>
      <button class="btn" onclick="toggleFullscreen()">Fullscreen</button>
    </div>
    <iframe id="gameFrame" src="" allow="fullscreen; autoplay; camera; microphone; clipboard-write" sandbox="allow-forms allow-scripts allow-same-origin allow-popups"></iframe>
  </div>

  <script>
    // --- Security: Block Context Menu & Shortcuts ---
    const customMenu = document.getElementById('custom-menu');
    let currentTargetUrl = '';

    document.addEventListener('contextmenu', function(e) {
      e.preventDefault();
      const card = e.target.closest('.game-card');
      if (card && !card.classList.contains('add-btn')) {
        // Extract URL from the onclick attribute
        const match = card.getAttribute('onclick').match(/'([^']+)'/);
        if (match) {
          currentTargetUrl = match[1];
          customMenu.style.display = 'block';
          customMenu.style.left = e.pageX + 'px';
          customMenu.style.top = e.pageY + 'px';
        }
      } else {
        customMenu.style.display = 'none';
      }
    });

    customMenu.onclick = () => {
      loadGame(currentTargetUrl);
      customMenu.style.display = 'none';
    };

    document.addEventListener('click', () => customMenu.style.display = 'none');

    // Block Ctrl+T, Ctrl+N, Ctrl+Shift+I
    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && (e.key === 't' || e.key === 'n' || e.key === 'p')) e.preventDefault();
      if (e.ctrlKey && e.shiftKey && e.key === 'I') e.preventDefault();
    });

    // --- Matrix Rain ---
    const canvas = document.getElementById("matrix");
    const ctx = canvas.getContext("2d");
    let matrixInterval = null;
    const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
    const fontSize = 16;
    let drops = [];

    function initMatrix() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      const cols = Math.floor(canvas.width / fontSize);
      drops = Array(cols).fill(1);
    }

    function drawMatrix() {
      ctx.fillStyle = "rgba(2, 6, 13, 0.15)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = "#00d2ff";
      ctx.font = fontSize + "px monospace";
      for (let i = 0; i < drops.length; i++) {
        const text = chars[Math.floor(Math.random() * chars.length)];
        ctx.fillText(text, i * fontSize, drops[i] * fontSize);
        if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
        drops[i]++;
      }
    }

    initMatrix();
    matrixInterval = setInterval(drawMatrix, 35);
    window.onresize = initMatrix;

    // --- Dynamic Greeting ---
    function updateGreeting() {
      const h = new Date().getHours();
      let t = "Welcome, Ituze";
      if (h < 12) t = "Good morning, Ituze";
      else if (h < 18) t = "Good afternoon, Ituze";
      else t = "Good evening, Ituze";
      document.getElementById("greeting").textContent = t;
    }
    updateGreeting();

    // --- Navigation ---
    function loadGame(url) {
      if (!url.startsWith('http')) url = 'https://' + url;
      document.getElementById('gameFrame').src = url;
      document.getElementById('menu').style.display = 'none';
      document.getElementById('stage').style.display = 'flex';
      clearInterval(matrixInterval);
    }

    function goBack() {
      document.getElementById('gameFrame').src = 'about:blank';
      document.getElementById('menu').style.display = 'flex';
      document.getElementById('stage').style.display = 'none';
      matrixInterval = setInterval(drawMatrix, 35);
    }

    function toggleFullscreen() {
      const stage = document.getElementById('stage');
      if (!document.fullscreenElement) stage.requestFullscreen();
      else document.exitFullscreen();
    }

    // --- Add Game ---
    function addCustomGame() {
      const name = prompt("Enter Game Name:");
      if (!name) return;
      let url = prompt("Enter URL:");
      if (!url) return;

      const newCard = document.createElement("div");
      newCard.className = "game-card";
      newCard.textContent = name;
      newCard.onclick = () => loadGame(url);

      const list = document.getElementById("gameList");
      list.insertBefore(newCard, list.querySelector(".add-btn"));
    }
  </script>
</body>
</html>
